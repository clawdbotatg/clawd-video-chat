# ── clawd-video-chat server ──────────────────────────────────────────────────
PORT=7900

# ── OpenClaw gateway (auto-detected from ~/.openclaw/openclaw.json if blank) ─
# Override if your gateway lives elsewhere or uses a different token.
OPENCLAW_WS_URL=
OPENCLAW_TOKEN=
OPENCLAW_SESSION_KEY=agent:clawd:main

# ── Bankr LLM API key (powers Haiku stall-talk while clawd thinks) ───────────
BANKR_LLM_KEY=

# ── ElevenLabs (preferred TTS — Flash v2.5, ~200ms TTFB) ─────────────────────
# Strongly recommended for video-chat — without low-latency TTS the call feels
# laggy. Default voice is Brian (deep American male). Browse the public voice
# library at https://elevenlabs.io/app/voice-library and paste another voice
# ID below to swap.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# ── OpenAI key (fallback TTS — gpt-4o-mini-tts onyx voice, ~2s latency) ──────
# Used if no ElevenLabs key is set. Higher latency but richer instruction
# steering. Without either key the page falls back to browser speechSynthesis,
# which OBS will *not* capture cleanly.
OPENAI_API_KEY=
