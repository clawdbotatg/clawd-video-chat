# ── clawd-video-chat server (port 7900 — UI, STT, TTS) ───────────────────────
PORT=7900

# ── Brain wiring (claude-p-agent + cc-bridge on 7861) ─────────────────────────
# The UI talks to cc-bridge.py over the gateway WS protocol. Point wsUrl at the
# bridge, not openclaw.
OPENCLAW_WS_URL=ws://127.0.0.1:7861
OPENCLAW_TOKEN=
OPENCLAW_SESSION_KEY=agent:clawd:main

# Engine install (import agent.run_turn) — github.com/clawdbotatg/claude-p-agent
# CLAUDE_P_AGENT_HOME=/path/to/claude-p-agent

# Brain workspace: a clone with YOUR CLAUDE.md + tools. cc-bridge runs claude -p here.
# CC_BRIDGE_CWD=/path/to/your/brain-clone

# STT transcript log (optional; lives in brain cwd by convention)
# STT_LOG_PATH=/path/to/your/brain-clone/stt-log.jsonl

# cc-bridge extras (usually set in launchd or when starting cc-bridge.py)
# CC_BRIDGE_PORT=7861
# CC_BRIDGE_MODEL=opus

# ── Bankr LLM (Haiku stall-talk while the brain thinks) ───────────────────────
BANKR_LLM_KEY=

# ── ElevenLabs TTS (strongly recommended for video) ───────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# ── OpenAI TTS fallback ───────────────────────────────────────────────────────
OPENAI_API_KEY=
